model RentalOrder {
  id            String        @id @default(uuid())
  status        OrderStatus   @default(PLACED)
  startDate     DateTime
  endDate       DateTime
  totalDays     Int
  totalAmount   Float


  customerId    String

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt


  customer      User          @relation(fields: [customerId], references: [id])
  items         RentalItem[]
  payment       Payment?
}