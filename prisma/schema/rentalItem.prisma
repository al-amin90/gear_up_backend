model RentalItem {
  id            String      @id @default(uuid())
  quantity      Int         @default(1)
  pricePerDay   Float
  subtotal      Float

  rentalOrderId String
  gearItemId    String

  rentalOrder   RentalOrder @relation(fields: [rentalOrderId], references: [id])
  gears     Gear    @relation(fields: [gearItemId], references: [id])

     @@map("rentalItems")
}