model User {
  id           String       @id @default(uuid())
  name         String       @db.VarChar(255)
  email        String       @unique
  password     String
  isActive   Boolean @default(true)
  role         Role         @default(CUSTOMER)
  phone       String?
  address     String?

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt


  gears Gear[]
  rentals     RentalOrder[]
  reviews     Review[]
  payments    Payment[]
  @@map("users")
}
